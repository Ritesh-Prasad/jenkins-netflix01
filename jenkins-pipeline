pipeline {
    agent any
    tools {
        maven 'maven'
    }
    environment {
        SCANNER_HOME = tool 'mysonar'  // SonarQube scanner installation
    }
    stages {
        stage('Clean Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Checkout Code') {
            steps {
                git 'https://github.com/RAHAMSHAIK007/jenkins-java-project.git'
            }
        }

        stage('Build') {
            steps {
                sh 'mvn clean compile'
            }
        }

        stage('Test') {
            steps {
                sh 'mvn test'
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('mysonar') {
                    sh """
                        $SCANNER_HOME/bin/sonar-scanner -X \
                        -Dsonar.projectName=jenkins-netflix01 \
                        -Dsonar.projectKey=jenkins-netflix01 \
                        -Dsonar.sources=src/main/java \
                        -Dsonar.tests=src/test/java \
                        -Dsonar.java.binaries=target/classes \
                        -Dsonar.host.url=$SONAR_HOST_URL \
                        -Dsonar.login=$SONAR_AUTH_TOKEN
                    """
                }
            }
        }

        stage('Package Artifacts') {
            steps {
                sh 'mvn package'
            }
        }

        stage('Trivy Scan Workspace') {
            steps {
                sh 'trivy fs . > trivyfs.txt'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t netflix01 .'
            }
        }

        stage('Tag & Push Docker Image') {
            steps {
                withDockerRegistry(credentialsId: 'docker-password', url: 'https://index.docker.io/v1/') {
                    sh 'docker tag netflix01 riteshprasad07/mydockerproject3:latest'
                    sh 'docker push riteshprasad07/mydockerproject3:latest'
                }
            }
        }

        stage('Trivy Scan Docker Image') {
            steps {
                sh 'trivy image riteshprasad07/mydockerproject3:latest'
            }
        }

        stage('Run Container') {
            steps {
                sh 'docker run -d --name cont1 -p 8081:8080 riteshprasad07/mydockerproject3:latest'
            }
        }
    }
}
